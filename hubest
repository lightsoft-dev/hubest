#!/bin/bash
# hubest — Claude Code Multi-Session Manager (Interactive CLI)
HUBEST_DIR="$HOME/.hubest"

case "${1:-}" in
  init)
    shift
    python3 "$HUBEST_DIR/hubest_cli.py" init "$@"
    exit $?
    ;;
  add)
    shift
    python3 "$HUBEST_DIR/hubest_cli.py" add "$@"
    exit $?
    ;;
  --help|-h|help)
    python3 "$HUBEST_DIR/hubest_cli.py" help
    exit 0
    ;;
  --version|-v)
    echo "hubest v0.1.0"
    exit 0
    ;;
esac

# Default: enter interactive shell
python3 "$HUBEST_DIR/hubest_cli.py" interactive
